<%- include('partials/header') %>

<section class="form-section">
  <h1>Edit Book</h1>

  <form action="/edit/<%= book.id %>" method="POST">

    <div class="form-group">
      <label for="title">Book Title</label>
      <input type="text" id="title" name="title" value="<%= book.title %>" required />
    </div>

    <div class="form-group">
      <label for="author">Author</label>
      <input type="text" id="author" name="author" value="<%= book.author %>" required />
    </div>

    <div class="form-group">
      <label for="rating">Rating (1-10)</label>
      <input type="number" id="rating" name="rating" min="1" max="10" value="<%= book.rating %>" required />
    </div>

    <div class="form-group">
      <label for="date_read">Date Read</label>
      <input type="date" id="date_read" name="date_read" value="<%= book.date_read ? book.date_read.toISOString().split('T')[0] : '' %>" required />
    </div>

    <div class="form-group">
      <label for="isbn">ISBN</label>
      <input type="text" id="isbn" name="isbn" value="<%= book.isbn %>" />
      <small>Used to fetch the book cover.</small>
    </div>

    <div class="form-group">
      <label for="notes">Notes / Summary</label>
      <textarea id="notes" name="notes" rows="6"><%= book.notes %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-submit">Update Book</button>
      <a href="/" class="btn-cancel">Cancel</a>
    </div>

  </form>
</section>

<%- include('partials/footer') %>